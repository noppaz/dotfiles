#!/bin/zsh

echo "Setting up your Mac..."

# Load env vars
source $HOME/.dotfiles/.zshenv

# Add homebrew to shell
eval "$(/opt/homebrew/bin/brew shellenv)"

# Update Homebrew recipes
brew update

# Install all our dependencies with bundle (See Brewfile)
brew bundle

# Create XDG base directories
for dir in "$XDG_CONFIG_HOME" "$XDG_CACHE_HOME" "$XDG_DATA_HOME" "$XDG_STATE_HOME" "$HOME/.local/bin"; do
  mkdir -p "$dir"
done

# Install Oh My Zsh if not already installed
if [ ! -d "$ZSH" ]; then
  sh -c "$(curl -fsSL https://raw.githubusercontent.com/robbyrussell/oh-my-zsh/master/tools/install.sh)" "" --unattended
fi

# Symlink .zshrc
ln -sfnv $HOME/.dotfiles/.zshrc $HOME/.zshrc

# Symlink .zshenv
ln -sfnv $HOME/.dotfiles/.zshenv $HOME/.zshenv

# Git config
ln -sfnv $HOME/.dotfiles/.gitconfig $HOME/.gitconfig

# Ghostty config
mkdir -p $XDG_CONFIG_HOME/ghostty
ln -sfnv $HOME/.dotfiles/ghostty/config $XDG_CONFIG_HOME/ghostty/config

# Zed config
mkdir -p $XDG_CONFIG_HOME/zed
ln -sfnv $HOME/.dotfiles/zed/settings.json $XDG_CONFIG_HOME/zed/settings.json

# Neovim config
ln -sfnv $HOME/.dotfiles/nvim $XDG_CONFIG_HOME/nvim

# Add Golang folders
mkdir -p $HOME/go
go get golang.org/x/tools/cmd/godoc
go get github.com/golang/lint/golint

# Docker buildx
mkdir -p $HOME/.docker/cli-plugins
ln -sfnv $(which docker-buildx) $HOME/.docker/cli-plugins/docker-buildx

# Set macOS preferences - reloads shell
source .macos
