#!/bin/zsh

echo "Setting up your Mac..."

# Update Homebrew recipes
brew update

# Install all our dependencies with bundle (See Brewfile)
brew bundle

# Create XDG base directories
for dir in "$HOME/.config" "$HOME/.cache" "$HOME/.local/share" "$HOME/.local/state" "$HOME/.local/bin"; do
  mkdir -p "$dir"
done

# Install Oh My Zsh if not already installed
if [ ! -d "$HOME/.oh-my-zsh" ]; then
  sh -c "$(curl -fsSL https://raw.githubusercontent.com/robbyrussell/oh-my-zsh/master/tools/install.sh)" "" --unattended
fi

# Removes .zshrc from $HOME (if it exists) and symlinks the .zshrc file from the .dotfiles
rm -rf $HOME/.zshrc
ln -sfnv $HOME/.dotfiles/.zshrc $HOME/.zshrc

# Symlink git config file
ln -sfnv $HOME/.dotfiles/.gitconfig $HOME/.gitconfig

# Ghostty config
mkdir -p $HOME/.config/ghostty
ln -sfnv $HOME/.dotfiles/ghostty/config $HOME/.config/ghostty/config

# Zed config
mkdir -p $HOME/.config/zed
ln -sfnv $HOME/.dotfiles/zed/settings.json $HOME/.config/zed/settings.json

# Neovim config
ln -sfnv $HOME/.dotfiles/nvim $HOME/.config/nvim

# Add Golang folders
mkdir -p $HOME/go
go get golang.org/x/tools/cmd/godoc
go get github.com/golang/lint/golint

# Docker buildx
mkdir -p $HOME/.docker/cli-plugins
ln -sfnv $(which docker-buildx) $HOME/.docker/cli-plugins/docker-buildx

# Set macOS preferences - reloads shell
source .macos
